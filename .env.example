# ============================================================
# Metis FastAPI — Example Environment File
# ============================================================
# Copy this file to `.env` and fill in real values:
#     cp .env.example .env        (Linux / macOS)
#     copy .env.example .env      (Windows cmd)
#     Copy-Item .env.example .env (PowerShell)
#
# Variables marked [REQUIRED] must be set or the app will fail
# to start (see src/configs/application.yaml). Everything else
# falls back to the default shown in the comment.
#
# Loading order (highest priority first):
#   1. OS environment variables
#   2. .env (this file, when copied)
#   3. Defaults declared in src/configs/application.yaml
# ------------------------------------------------------------


# ─── Application ────────────────────────────────────────────
# General app metadata + runtime mode.
APP_NAME=Metis
APP_VERSION=0.1.0
# DEBUG=true enables verbose logging and dev-only endpoints.
# Always set this to false in production.
DEBUG=true
# One of: development | staging | production
ENVIRONMENT=development


# ─── Database (PostgreSQL via asyncpg) ──────────────────────
# [REQUIRED] Async SQLAlchemy URL. Format:
#   postgresql+asyncpg://<user>:<password>@<host>:<port>/<db>
DATABASE_URL=postgresql+asyncpg://postgres:CHANGE_ME@localhost:5432/bandits

# Connection pool tuning. Defaults are sane for local dev;
# raise pool_size / max_overflow under production load.
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
# DB_ECHO=true logs every SQL statement — useful when
# debugging queries, noisy otherwise.
DB_ECHO=false


# ─── Security / JWT ─────────────────────────────────────────
# [REQUIRED] Signing key for access + refresh tokens.
# Generate a strong random value, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
# NEVER commit the real value or reuse across environments.
JWT_SECRET_KEY=replace-this-with-a-secure-random-string

# HS256 is the default. Only change if you know why.
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7


# ─── Admin Seed User ────────────────────────────────────────
# Created on first startup if no admin exists. Change the
# password immediately after first login in any shared env.
ADMIN_EMAIL=admin@metis.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMe!1234


# ─── Token Cleanup ──────────────────────────────────────────
# Interval (seconds) for the background job that purges
# expired/revoked refresh tokens. 3600 = once per hour.
TOKEN_CLEANUP_INTERVAL=3600


# ─── CORS ───────────────────────────────────────────────────
# Comma-separated list of allowed origins. Use `*` only in
# dev — in prod, list the exact frontend hostnames.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:63342
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*


# ─── Logging ────────────────────────────────────────────────
# Standard Python log levels: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# Path is relative to the project root. Directory must exist
# (or be creatable) by the process user.
LOG_FILE_PATH=logs/metis.log


# ─── Bandit Model Artefacts ─────────────────────────────────
# Directory containing the trained NeuralThompson checkpoint
# and the matching feature pipeline. Use an absolute path if
# the artefacts live outside the repo.
MODEL_PATH=models
MODEL_FILE=neural_thompson.pt
PIPELINE_FILE=feature_pipeline_scaled.joblib


# ─── Gemini (LLM clinical explanations) ─────────────────────
# [REQUIRED] Get a key from https://aistudio.google.com/
# Treat this like a password — do not commit, do not share.
GEMINI_API_KEY=your-gemini-api-key-here

# Model name and sampling temperature for the explanation
# call. Lower temperature = more deterministic clinical text.
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0.3


# ─── Neo4j (clinical knowledge graph) ───────────────────────
NEO4J_URI=neo4j://localhost:7687
NEO4J_USERNAME=neo4j
# [REQUIRED] No default — the app will refuse to start
# without this. Match the password set in your Neo4j instance.
NEO4J_PASSWORD=CHANGE_ME
